<?xml version="1.0" encoding="utf-8"?>
<!--
  AutoCAD Bundle Manifest — Auto-loads the MCP plugin on startup.

  Install by running install.bat, or manually copy this entire
  AutoCADMCPPlugin.bundle folder to:
    %APPDATA%\Autodesk\ApplicationPlugins\

  Supports AutoCAD 2022-2026.
-->
<ApplicationPackage
  SchemaVersion="1.0"
  AutodeskProduct="AutoCAD"
  Name="AutoCAD MCP Plugin"
  Description="AI-to-AutoCAD communication via MCP protocol over TCP socket"
  AppVersion="1.0.0"
  ProductCode="{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}"
  UpgradeCode="{A1B2C3D4-E5F6-7890-ABCD-EF1234567891}">

  <CompanyDetails Name="AutoCAD MCP" />

  <!-- Support AutoCAD 2022 (R24.1) through 2026 (R25.1) -->
  <RuntimeRequirements
    OS="Win64"
    Platform="AutoCAD"
    SeriesMin="R24.1"
    SeriesMax="R25.1" />

  <Components>

    <!-- AutoCAD 2022-2024 (.NET Framework 4.8) -->
    <ComponentEntry
      AppName="AutoCADMCPPlugin_net48"
      Version="1.0.0"
      ModuleName="./Contents/net48/AutoCADMCPPlugin.dll"
      AppDescription="AutoCAD MCP Plugin (.NET Framework 4.8)"
      LoadOnAutoCADStartup="True"
      LoadOnCommandInvocation="False">
      <RuntimeRequirements SeriesMin="R24.1" SeriesMax="R24.3" />
    </ComponentEntry>

    <!-- AutoCAD 2025-2026 (.NET 8) -->
    <ComponentEntry
      AppName="AutoCADMCPPlugin_net8"
      Version="1.0.0"
      ModuleName="./Contents/net8.0-windows/AutoCADMCPPlugin.dll"
      AppDescription="AutoCAD MCP Plugin (.NET 8)"
      LoadOnAutoCADStartup="True"
      LoadOnCommandInvocation="False">
      <RuntimeRequirements SeriesMin="R25.0" SeriesMax="R25.1" />
    </ComponentEntry>

  </Components>

</ApplicationPackage>
